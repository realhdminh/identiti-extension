{
  "name": "identiti",
  "description": "Export and import browser site data (cookies, storage, IndexedDB) with optional encryption.",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "bun test",
    "postinstall": "wxt prepare",
    "lint": "biome check --unsafe src",
    "format": "biome check --write --unsafe src"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-virtual": "^3.14.5",
    "@webext-core/messaging": "^2.3.0",
    "@wxt-dev/auto-icons": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-window": "^2.2.7",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^2.0.0",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^5.9.3",
    "wxt": "^0.20.27"
  }
